{
    "name": "snowmannunu/weather",
    "description": "A weather SDK based on AMap (Gaode) Open API.",
    "keywords": ["weather", "amap", "gaode", "sdk", "php", "laravel"],
    "homepage": "https://github.com/SnowmanNunu/weather",
    "license": "MIT",
    "authors": [
        {
            "name": "Snowman",
            "email": "345750542@qq.com"
        }
    ],
    "require": {
        "php": "^7.3|^8.0",
        "guzzlehttp/guzzle": "^7.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "SnowmanNunu\\Weather\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SnowmanNunu\\Weather\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SnowmanNunu\\Weather\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    }
}
