{
    "name": "snowmannunu/weather",
    "description": "A weather SDK with multi-provider support (AMap, QWeather, etc.).",
    "keywords": ["weather", "amap", "gaode", "qweather", "sdk", "php", "laravel"],
    "homepage": "https://github.com/SnowmanNunu/weather",
    "license": "MIT",
    "authors": [
        {
            "name": "Snowman",
            "email": "345750542@qq.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.7",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "psr/simple-cache": "^3.0"
    },
    "suggest": {
        "psr/simple-cache": "Required for caching weather responses"
    },
    "autoload": {
        "psr-4": {
            "SnowmanNunu\\Weather\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SnowmanNunu\\Weather\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SnowmanNunu\\Weather\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "phpcs": "vendor/bin/phpcs src tests --standard=PSR12",
        "phpcbf": "vendor/bin/phpcbf src tests --standard=PSR12",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    }
}
